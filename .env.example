POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_PORT=5432

DATABASE_URL=postgresql://appuser:apppass@localhost:5432/appdb
BACKEND_PORT=8000
FRONTEND_PORT=5173
AI_SERVICE_URL=http://localhost:9000
RF_SERVER_URL=http://localhost:9000
OPENAI_API_KEY=

# ===========================
# Auth / JWT
# ===========================
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===========================
# Internal API Key (AI 서버 → 백엔드 호출용)
# ===========================
INTERNAL_API_KEY=change-me-internal-key

# ===========================
# CORS
# ===========================
CORS_ALLOW_ORIGINS=http://localhost:5173

ASSETS_DIR=data/assets

# ===========================
# Calibration (§11 BO 파라미터 보정)
# ===========================
# false 로 두면 calibration job 이 BO 를 돌리지 않고 baseline(미보정) 상태로 바로 completed 처리됨.
CALIBRATION_BO_ENABLED=true
