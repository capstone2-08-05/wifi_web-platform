{
  "type": "object",
  "required": ["scene_version", "units", "sourceType", "walls", "openings", "rooms", "objects"],
  "properties": {
    "scene_version": { "type": "string" },

    "units": { "type": "string", "enum": ["m"] },
    "sourceType": { "type": "string" },

    "walls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x1", "y1", "x2", "y2", "thickness", "height", "role", "material"],
        "properties": {
          "id": { "type": "string" },
          "x1": { "type": "number" },
          "y1": { "type": "number" },
          "x2": { "type": "number" },
          "y2": { "type": "number" },
          "thickness": { "type": "number" },
          "height": { "type": "number" },
          "role": { "type": "string", "enum": ["outer", "inner"] },

          "material": {
            "type": "string",
            "enum": ["concrete", "glass", "wood", "metal", "unknown"]
          }
        }
      }
    },

    "openings": { "type": "array" },
    "rooms": { "type": "array" },
    "objects": { "type": "array" }
  }
}